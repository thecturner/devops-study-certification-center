{
  "name": "devops-study-certification-center",
  "version": "0.1.0",
  "description": "Practice quizzes for DevOps and cloud certification exams",
  "repository": {
    "type": "git",
    "url": "https://github.com/thecturner/devops-study-certification-center.git"
  },
  "homepage": "https://github.com/thecturner/devops-study-certification-center",
  "license": "MIT",
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=src/__tests__/integration",
    "test:integration": "jest src/__tests__/integration --runInBand",
    "test:e2e": "playwright test",
    "validate-questions": "tsx scripts/validate-questions.ts"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.30.1",
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dd-trace": "^5.88.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.53.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dd-trace": "^0.7.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^30.2.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
