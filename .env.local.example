# Datadog RUM (browser) — site works without these; RUM just won't initialize
NEXT_PUBLIC_DD_APPLICATION_ID=your-dd-application-id
NEXT_PUBLIC_DD_CLIENT_TOKEN=your-dd-client-token
NEXT_PUBLIC_DD_ENV=production

# Datadog APM (server-side API routes) — optional
DD_API_KEY=your-dd-api-key
DD_SERVICE=dd-fundamentals-site
DD_ENV=production

# Question generation scripts (dev only) — optional
# Required only to run scripts/generate-questions.ts and scripts/scrape-ccaf-docs.sh
# ANTHROPIC_API_KEY=your-anthropic-api-key
