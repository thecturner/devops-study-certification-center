# Copy this file to .env.local and fill in your values.
# All variables are optional — the app runs without them.
# cp .env.example .env.local

# === Datadog RUM (browser monitoring) ===
# Get these from your Datadog account: UX Monitoring > RUM Applications
NEXT_PUBLIC_DD_APPLICATION_ID=your-dd-application-id
NEXT_PUBLIC_DD_CLIENT_TOKEN=your-dd-client-token
NEXT_PUBLIC_DD_ENV=production

# === Datadog APM (server-side tracing) ===
# Get your API key from: Organization Settings > API Keys
DD_API_KEY=your-dd-api-key
DD_SERVICE=dd-fundamentals-site
DD_ENV=production
